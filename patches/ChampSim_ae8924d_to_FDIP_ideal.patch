+bool CacheBus::issue_prefetch(request_type data_packet)
+{
+  data_packet.address = data_packet.v_address;
+  data_packet.is_translated = false;
+  data_packet.cpu = cpu;
+  data_packet.type = access_type::PREFETCH;
