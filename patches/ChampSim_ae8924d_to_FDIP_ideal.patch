+// inwook: Simplified to only track issuance. Reset is done by CPU via
+// get_and_reset_prefetch_stats.
+void CACHE::track_prefetch_issuance() { pf_interval_issued++; }
+
+void CACHE::track_utility_and_timeliness(bool is_useful, bool is_timely)
+{
+  if (is_useful) {
+    pf_interval_useful++;
+    if (is_timely) {
+      pf_interval_timely++;
+    }
+  }
+}
+// inwook: New function to calculate stats on demand and reset counters
+std::pair<double, double> CACHE::get_and_reset_prefetch_stats()
+{
+  double utility = 0.0;
+  double timeliness = 0.0;
+
+  if (pf_interval_issued > 0) {
+    utility = (double)pf_interval_useful / (double)pf_interval_issued;
+  }
+
+  if (pf_interval_useful > 0) {
+    timeliness = (double)pf_interval_timely / (double)pf_interval_useful;
+  }
+
+  // Reset counters
+  pf_interval_issued = 0;
+  pf_interval_useful = 0;
+  pf_interval_timely = 0;
+
+  // Increment version to signal update (though with explicit call it's less
+  // critical, good for consistency)
+  pf_stats_version++;
+
+  return {utility, timeliness};
+}
