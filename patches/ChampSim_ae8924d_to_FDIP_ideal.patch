+// inwook start
+void O3_CPU::process_ftq()
+{
+  if (std::empty(FTQ)) {
+    return;
+  }
+
+  if (!ENABLE_FDIP) {
+    return;
+  }
+
+  // Iterate through FTQ, skipping the first entry (Head) because it is likely
+  // being demand-fetched right now. We want to prefetch FUTURE blocks (Tail).
+  // Iterate through FTQ, skipping the first entry (Head) because it is likely
+  // being demand-fetched right now. We want to prefetch FUTURE blocks (Tail).
+  if (std::empty(FTQ)) {
+    if (!warmup && (current_time.time_since_epoch() / clock_period) % 1000 == 0)
+      fmt::print("[FTQ] Process: FTQ Empty\n");
+    return;
+  }
+
+  int prefetch_count = 0;
+  int issued_count = 0;
+  for (auto it = std::next(FTQ.begin()); it != FTQ.end(); ++it) {
+    // if (prefetch_count >= 15)
+    //   break; // Limit lookahead to 15 entries
+    prefetch_count++;
+
+    if (it->fetch_state == 1) { // 1: Prediction Completed
+      // Issue Prefetch using CACHE::prefetch_line
+      bool success = l1i->prefetch_line(it->ip, true, 0);
+      if (success) {
+        it->fetch_state = 2; // 2: Wait for Fill
+        issued_count++;
+        ftq_accumulated_issued_count++;
+      } else {
+        break; // Bus full or MSHR full, stop for this cycle
+      }
+    }
+  }
+}
+// inwook start
+
+void O3_CPU::predict_future_blocks()
+{
+  if (!ENABLE_FDIP)
+    return;
+  if (input_queue.empty())
+    return;
+
+  // champsim::bandwidth instrs_to_scan_this_cycle{FETCH_WIDTH}; // 의도하신 대역폭 제한
+  int ftq_added_this_cycle = 0;
+
+  for (const auto& instr : input_queue) {
+    if (instr.instr_id <= ftq_last_scan_instr_id)
+      continue;
+
+    // 스캔 대역폭 소모
+    // instrs_to_scan_this_cycle.consume();
+
+    // 2. Fill Rate Limit: Stop if we already added 1 entry to FTQ this cycle
+    if (ftq_added_this_cycle >= 1) {
+      break;
+    }
+
+    uint64_t curr_ip = instr.ip.to<uint64_t>();
+    uint64_t curr_line = curr_ip >> FQ_OFFSET;
+    uint64_t last_line = ftq_last_scan_ip >> FQ_OFFSET;
+
+    // [수정 포인트 2: 순차 블록 체크 복구]
+    // 캐시 라인 경계를 넘었을 때 (SEQ Push)
+    if (ftq_last_scan_ip != 0 && curr_line != last_line) {
+      if (FTQ.size() >= FTQ_SIZE)
+        break;
+
+      FTQ_ENTRY new_entry;
+      new_entry.ip = champsim::address{last_line << FQ_OFFSET}; // 이전 블록 시작 주소
+      new_entry.taken = false;
+      new_entry.termination_offset = ftq_current_block_count - 1; // [수정 포인트 4: 카운트 기반 복구]
+      new_entry.fetch_state = 1;
+      new_entry.event_cycle = current_time.time_since_epoch() / clock_period;
+      std::copy(std::begin(instr.asid), std::end(instr.asid), std::begin(new_entry.asid));
+
+      FTQ.push_back(new_entry);
+      ftq_added_this_cycle++;      // Count added entry
+      ftq_current_block_count = 0; // 리셋
+    }
+
+    // 상태 업데이트
+    ftq_last_scan_ip = curr_ip;
+    ftq_current_block_count++;
+    ftq_last_scan_instr_id = instr.instr_id;
+
+    // [수정 포인트 2: 분기 블록 체크]
+    // 현재 명령어가 Taken Branch일 때 (BR Push)
+    if (instr.is_branch && instr.branch_taken) {
+      if (FTQ.size() >= FTQ_SIZE)
+        break;
+
+      FTQ_ENTRY new_entry;
+      new_entry.ip = champsim::address{curr_line << FQ_OFFSET}; // 현재 블록 시작 주소
+      new_entry.taken = true;
+      new_entry.termination_offset = ftq_current_block_count - 1;
+      new_entry.fetch_state = 1;
+      new_entry.event_cycle = current_time.time_since_epoch() / clock_period;
+      std::copy(std::begin(instr.asid), std::end(instr.asid), std::begin(new_entry.asid));
+
+      FTQ.push_back(new_entry);
+      ftq_added_this_cycle++; // Count added entry
+
+      ftq_current_block_count = 0; // 리셋
+      ftq_last_scan_ip = 0;        // 다음 명령어에서 새 블록 시작 강제
+    }
+
+    // 대역폭을 다 썼으면 루프 중단
+    // if (!instrs_to_scan_this_cycle.has_remaining())
+    //   break;
+  }
+}
