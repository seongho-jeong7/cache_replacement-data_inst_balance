+namespace
+{
+// STLB trace logging (writes TSV, optionally piped to xz when path ends with
+// .xz)
+FILE* stlb_trace_fp = nullptr;
+bool stlb_trace_is_pipe = false;
+
+inline const char* access_type_cstr(access_type t)
+{
+  switch (t) {
+  case access_type::LOAD:
+    return "LOAD";
+  case access_type::RFO:
+    return "RFO";
+  case access_type::PREFETCH:
+    return "PREFETCH";
+  case access_type::WRITE:
+    return "WRITE";
+  case access_type::TRANSLATION:
+    return "TRANSLATION";
+  default:
+    return "OTHER";
+  }
+}
+
+void stlb_trace_open_once()
+{
+  if (stlb_trace_fp)
+    return;
+  const char* path = std::getenv("STLB_HIT_TRACE");
+  if (!path || !*path)
+    return;
+
+  std::string out_path{path};
+  if (out_path.size() >= 3 && out_path.rfind(".xz") == out_path.size() - 3) {
+    std::string cmd = std::string{"xz -T0 > "} + out_path;
+    stlb_trace_fp = popen(cmd.c_str(), "w");
+    stlb_trace_is_pipe = true;
+  } else {
+    stlb_trace_fp = std::fopen(out_path.c_str(), "w");
+    stlb_trace_is_pipe = false;
+  }
+
+  if (stlb_trace_fp) {
+    // Fixed-width header for aligned columns (added type column, widened
+    // numeric widths)
+    std::fprintf(stlb_trace_fp, "%-10s %-6s %-28s %28s %28s %28s %28s\n", "type", "tlb_miss", "stlb_result", "vpn", "ppn", "pc", "offset");
+    std::fflush(stlb_trace_fp);
+  }
+}
+
+void stlb_trace_close()
+{
+  if (!stlb_trace_fp)
+    return;
+  if (stlb_trace_is_pipe)
+    pclose(stlb_trace_fp);
+  else
+    std::fclose(stlb_trace_fp);
+  stlb_trace_fp = nullptr;
+  stlb_trace_is_pipe = false;
+}
+
+inline void stlb_trace_write(const char* tlb_miss, const char* stlb_result, const char* type_s, uint64_t vpn, uint64_t ppn, uint64_t pc, uint32_t offset)
+{
+  if (!stlb_trace_fp)
+    return;
+  // Fixed-width row matching header widths: vpn/ppn/pc as hex, all numeric
+  // right-aligned to width 20
+  std::fprintf(stlb_trace_fp, "%-10s %-6s %-28s %28llx %28llx %28llx %28u\n", type_s, tlb_miss, stlb_result, (unsigned long long)vpn, (unsigned long long)ppn,
+               (unsigned long long)pc, (unsigned)offset);
+}
