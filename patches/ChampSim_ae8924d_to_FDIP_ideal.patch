diff --git a/config/generate_compile_commands.py b/config/generate_compile_commands.py
new file mode 100755
index 0000000..c009e87
--- /dev/null
+++ b/config/generate_compile_commands.py
@@ -0,0 +1,29 @@
+#!/usr/bin/env python3
+import json
+import subprocess
+import sys
+
+# Get compiler flags
+try:
+    with open('global.options', 'r') as f:
+        global_flags = f.read().strip().split()
+except:
+    global_flags = ['-std=c++17', '-O3']
+
+# Find all source files
+result = subprocess.run(['find', 'src', '-name', '*.cc'], capture_output=True, text=True)
+source_files = result.stdout.strip().split('\n')
+
+commands = []
+for src in source_files:
+    if not src:
+        continue
+    obj = src.replace('src/', '.csconfig/').replace('.cc', '.o')
+    cmd = {
+        "directory": subprocess.run(['pwd'], capture_output=True, text=True).stdout.strip(),
+        "command": f"g++ {' '.join(global_flags)} -I. -Iinc -Ivcpkg_installed/x64-linux/include -c {src} -o {obj}",
+        "file": src
+    }
+    commands.append(cmd)
+
+print(json.dumps(commands, indent=2))
